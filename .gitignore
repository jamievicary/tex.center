# Credentials — NEVER commit
creds/
*.token
*.pem
*.key
.env
.env.*
!.env.example

# Node toolchain (vendored per-checkout, see tests_normal/setup_node.sh)
.tools/

# Node
node_modules/
.pnpm-store/
dist/
build/
.svelte-kit/
.next/
.turbo/
.cache/
coverage/
*.log
npm-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Atomic-write temp files. `ProjectWorkspace.writeMain` uses
# `<target>.tmp`; the Claude Code Edit tool produces
# `<target>.tmp.<pid>.<ms>`. Either leaking past their rename is a
# bug — ignore so a leak stays untracked rather than landing in a
# commit (iter 25 committed one such file by accident).
*.tmp
*.tmp.[0-9]*

# Local TeX/build artefacts
*.aux
*.log
*.pdf
*.synctex.gz
*.fls
*.fdb_latexmk
*.out
*.toc
# Sidecar stub-compile fixture (will be deleted at M3 when supertex lands).
!apps/sidecar/fixtures/*.pdf

# Autodev internal state — keep out of the product repo
autodev/
/autodev/
