{
  "name": "@tex-center/db",
  "version": "0.0.0",
  "private": true,
  "description": "Persistence data model for tex.center: TypeScript entity types, Drizzle table builders, table specs, SQL migrations, and the postgres-js connection factory.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./migrations/*": "./src/migrations/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@types/node": "^20.16.13",
    "tsx": "^4.19.1"
  }
}
